# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

# --- Core Django ---
SECRET_KEY=change-this-to-a-random-50-char-string
DEBUG=True
DJANGO_SETTINGS_MODULE=samwa.settings.dev

# --- Hosts / CSRF (comma separated, no spaces) ---
# For local dev these aren't used (dev.py hardcodes localhost).
# For prod, put the exact subdomain cPanel gives you, e.g.:
# ALLOWED_HOSTS=samwabakery.co.zw,www.samwabakery.co.zw
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# --- Business branding (used to seed BakeryInfo) ---
BUSINESS_NAME=Samwa Bakery
BUSINESS_LOCATION=Mvurwi, Mashonaland Central
WHATSAPP_NUMBER=+263771234567
BRAND_COLOR=#d97706
